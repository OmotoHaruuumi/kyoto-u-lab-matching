# -------------------------------------------------------------------
# Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# -------------------------------------------------------------------

# ---- PostgreSQL ----
POSTGRES_USER=labmatch
POSTGRES_PASSWORD=labmatch_secret
POSTGRES_DB=labmatch_db

# Used by SQLAlchemy (async driver)
DATABASE_URL=postgresql+asyncpg://labmatch:labmatch_secret@db:5432/labmatch_db

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Google Gemini ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Embedding API ----
# Set to "true" to skip real Gemini calls and return mock vectors
MOCK_EMBEDDING=false
EMBEDDING_MODEL=models/text-embedding-004

# ---- SQLAlchemy debug ----
SQLALCHEMY_ECHO=false
