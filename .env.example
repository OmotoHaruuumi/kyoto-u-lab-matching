# -------------------------------------------------------------------
# Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# -------------------------------------------------------------------

# ---- PostgreSQL ----
POSTGRES_USER=labmatch
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=labmatch_db

# Used by SQLAlchemy (async driver)
# Replace <user>, <password>, <host>, <port>, <db> with actual values.
DATABASE_URL=postgresql+asyncpg://<user>:<password>@db:5432/<db>

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Google Gemini ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Embedding API ----
# Set to "true" to skip real Gemini calls and return mock vectors (for local dev/testing)
MOCK_EMBEDDING=false
EMBEDDING_MODEL=models/text-embedding-004

# Internal service URL for search_api → embedding_api communication (Docker network)
EMBEDDING_API_URL=http://embedding_api:8001

# ---- Search API ----
# Internal service URL for frontend → search_api communication (Docker network)
SEARCH_API_URL=http://search_api:8000

# ---- SQLAlchemy debug ----
SQLALCHEMY_ECHO=false
